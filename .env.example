# ============================================================
# VARIÁVEIS DE AMBIENTE - Agemar Governança de Reuniões
# Copie este arquivo para .env e preencha os valores reais.
# ============================================================

# --- Banco de Dados MariaDB ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=agemar_governanca_db

# --- Servidor Backend ---
SERVER_PORT=3001
FRONTEND_URL=http://localhost:3000

# --- JWT (gere uma chave aleatória segura para produção) ---
JWT_SECRET=agemar_governanca_secret_troque_em_producao

# --- LDAP ---
# LDAP_STRICT=true  -> exige LDAP ativo para login (padrão em produção)
# LDAP_STRICT=false -> permite login sem LDAP (modo contingência/desenvolvimento)
LDAP_STRICT=false

# --- Ambiente ---
NODE_ENV=development
